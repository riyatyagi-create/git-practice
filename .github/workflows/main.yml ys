name: Advanced CI

on:
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Step 1 - Checkout
        uses: actions/checkout@v3

      - name: Step 2 - Setup Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.x'

      - name: Step 3 - Install dependencies
        run: echo "No dependencies"

      - name: Step 4 - Run app
        run: python app.py

      - name: Step 5 - Final message
        run: echo "CI Pipeline Completed ✅"

